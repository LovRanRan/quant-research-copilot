# ======================================================================
# Project 3 · quant-research-copilot · Environment Variables Template
# Copy this file to .env and fill in real values. .env is gitignored.
# ======================================================================

# --- LLM Providers ---
ANTHROPIC_API_KEY=

# (Optional) OpenAI for embeddings / alt models
# OPENAI_API_KEY=

# --- MCP Server #1: mcp-sec-edgar ---
# SEC EDGAR requires a User-Agent string: "Your Name your.email@example.com"
# Without it, all requests return 403. See https://www.sec.gov/os/accessing-edgar-data
SEC_USER_AGENT="Your Name your.email@example.com"

# --- MCP Server #2: mcp-fred-macro ---
# Free API key: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# --- MCP Server #3: mcp-backtest ---
# No API key needed (uses yfinance)

# --- Community MCP Server #4: arxiv-mcp ---
# No API key needed

# --- Community MCP Server #5: tavily-mcp ---
# Free tier key: https://tavily.com
TAVILY_API_KEY=

# --- LangSmith Tracing (Stage 9) ---
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=quant-research-copilot
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# --- Runtime ---
LOG_LEVEL=INFO