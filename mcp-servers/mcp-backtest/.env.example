# mcp-backtest — local-only, no required secrets (yfinance is free/unauthenticated)

# Optional: override the parquet cache dir (default = ./.cache/backtest)
# BACKTEST_CACHE_DIR=./.cache/backtest

# Optional: override yfinance request timeout in seconds (default = 30)
# BACKTEST_YF_TIMEOUT=30

# Optional: where to persist backtest run results (default = ./.cache/backtest/runs)
# BACKTEST_RESULTS_DIR=./.cache/backtest/runs